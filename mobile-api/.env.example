# Copie este arquivo para .env e ajuste os valores
# cp .env.example .env

# Server
PORT=3000

# PostgreSQL
DB_HOST=localhost      # Use "db" quando rodar via Docker Compose
DB_PORT=5432
DB_NAME=mobile_db
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=troque_este_secret_em_producao
JWT_EXPIRES_IN=7d
